# Normalize line endings to LF in the repo (consistent across Windows/macOS/Linux).
* text=auto eol=lf

# Treat binary assets as binary (no EOL conversion / diffing).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.docx binary
*.pdf binary
