{
  // Cloudflare Workers — Static Assets deploy for the CASCADE-EPC SPA.
  // Build with `npm run build` (outputs ./dist); this Worker just serves those
  // assets, falling back to index.html so client-side routes don't 404.
  "name": "cascade-epc",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
